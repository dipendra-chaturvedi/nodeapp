<!DOCTYPE html>
<html>
<head>
    <title>User List</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

<div class="max-w-4xl mx-auto mt-10 bg-white shadow-lg rounded-lg p-6">

    <h1 class="text-2xl font-bold mb-4">User List</h1>

    <a href="/add" class="inline-block mb-4 bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
        + Add User
    </a>

    <ul class="space-y-2">
        <% if (users && users.length > 0) { %>
            <% users.forEach(user => { %>
                <li class="flex justify-between items-center border p-3 rounded">

                    <div>
                        <p class="font-semibold"><%= user.name %></p>
                        <p class="text-gray-500 text-sm"><%= user.email %></p>
                    </div>

                    <div class="space-x-2">
                        <a href="/view/<%= user.id %>" class="text-blue-500">View</a>
                        <a href="/edit/<%= user.id %>" class="text-yellow-500">Edit</a>
                        <a href="/delete/<%= user.id %>" class="text-red-500">Delete</a>
                    </div>

                </li>
            <% }) %>
        <% } else { %>
            <li class="text-gray-500">No users found</li>
        <% } %>
    </ul>

</div>

</body>
</html>