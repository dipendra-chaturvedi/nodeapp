<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UserHub — Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { display: ['Syne', 'sans-serif'], body: ['DM Sans', 'sans-serif'] },
          colors: {
            accent: { DEFAULT: '#6366f1', hover: '#4f46e5', muted: '#6366f120' },
            surface: { 1: '#0f0f13', 2: '#16161d', 3: '#1e1e28', 4: '#262634' },
          }
        }
      }
    }
  </script>
  <style>
    * { font-family: 'DM Sans', sans-serif; }
    h1,h2,h3,.font-display { font-family: 'Syne', sans-serif; }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #0f0f13; }
    ::-webkit-scrollbar-thumb { background: #6366f140; border-radius: 2px; }

    .sidebar { transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); }
    .nav-link { transition: all 0.15s ease; position: relative; }
    .nav-link::before {
      content: '';
      position: absolute; left: 0; top: 50%; transform: translateY(-50%);
      width: 3px; height: 0; background: #6366f1;
      border-radius: 0 2px 2px 0;
      transition: height 0.2s ease;
    }
    .nav-link.active::before, .nav-link:hover::before { height: 60%; }
    .nav-link.active { background: #6366f115; color: #818cf8; }

    .stat-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px #6366f118; }

    .user-row { animation: rowIn 0.4s cubic-bezier(0.16,1,0.3,1) both; }
    @keyframes rowIn {
      from { opacity: 0; transform: translateX(-8px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .user-row:nth-child(1)  { animation-delay: 0.04s; }
    .user-row:nth-child(2)  { animation-delay: 0.08s; }
    .user-row:nth-child(3)  { animation-delay: 0.12s; }
    .user-row:nth-child(4)  { animation-delay: 0.16s; }
    .user-row:nth-child(5)  { animation-delay: 0.20s; }
    .user-row:nth-child(6)  { animation-delay: 0.24s; }
    .user-row:nth-child(7)  { animation-delay: 0.28s; }
    .user-row:nth-child(8)  { animation-delay: 0.32s; }

    .action-btn { transition: all 0.15s ease; }
    .action-btn:hover { transform: scale(1.08); }

    .avatar { background: linear-gradient(135deg, #6366f1, #a78bfa); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.35s ease both; }

    .modal-overlay { transition: opacity 0.2s ease; }
    .modal-box { transition: transform 0.25s cubic-bezier(0.16,1,0.3,1), opacity 0.2s ease; }

    .glow-dot { box-shadow: 0 0 0 3px #10b98130; }

    /* Mobile sidebar overlay */
    .sidebar-overlay { transition: opacity 0.3s ease; }
  </style>
</head>

<body class="bg-[#0f0f13] text-slate-100 min-h-screen flex overflow-x-hidden">

  <!-- ===== SIDEBAR OVERLAY (mobile) ===== -->
  <div id="sidebarOverlay" onclick="closeSidebar()"
    class="sidebar-overlay fixed inset-0 bg-black/60 backdrop-blur-sm z-30 opacity-0 pointer-events-none lg:hidden"></div>

  <!-- ===== SIDEBAR ===== -->
  <aside id="sidebar"
    class="sidebar fixed lg:static top-0 left-0 z-40 w-64 h-screen bg-[#16161d] border-r border-white/5 flex flex-col -translate-x-full lg:translate-x-0 flex-shrink-0">

    <!-- Logo -->
    <div class="flex items-center gap-3 px-6 py-5 border-b border-white/5">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center shadow-lg shadow-indigo-500/25">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <circle cx="9" cy="7" r="3" fill="white"/>
          <path d="M3 16c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <p class="font-display font-700 text-sm text-white leading-none">UserHub</p>
        <p class="text-[10px] text-slate-500 mt-0.5">Admin Panel</p>
      </div>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <p class="text-[10px] font-600 text-slate-600 uppercase tracking-widest px-3 mb-2">Menu</p>

      <a href="/" class="nav-link active flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-200">
        <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
          </svg>
        </span>
        Dashboard
      </a>

      <a href="/add" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-400 hover:text-slate-200 hover:bg-white/5">
        <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
          </svg>
        </span>
        Add User
      </a>

      <div class="pt-4">
        <p class="text-[10px] font-600 text-slate-600 uppercase tracking-widest px-3 mb-2">System</p>
        <a href="#" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-400 hover:text-slate-200 hover:bg-white/5">
          <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 text-slate-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.07 4.93A10 10 0 1 0 4.93 19.07"/>
            </svg>
          </span>
          Settings
        </a>
      </div>
    </nav>

    <!-- Bottom: DB status -->
    <div class="px-4 py-4 border-t border-white/5">
      <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-emerald-500/5 border border-emerald-500/10">
        <span class="glow-dot w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
        <div>
          <p class="text-xs font-500 text-emerald-300">Database Online</p>
          <p class="text-[10px] text-slate-500">MySQL · Connected</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="flex-1 flex flex-col min-w-0">

    <!-- Top bar -->
    <header class="sticky top-0 z-20 bg-[#0f0f13]/80 backdrop-blur border-b border-white/5 px-5 py-3.5 flex items-center justify-between gap-4">
      <!-- Hamburger (mobile) -->
      <button onclick="openSidebar()" class="lg:hidden w-9 h-9 flex items-center justify-center rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <div class="flex-1">
        <h1 class="font-display font-700 text-base text-white">Dashboard</h1>
        <p class="text-xs text-slate-500">Welcome back to UserHub</p>
      </div>

      <div class="flex items-center gap-2">
        <!-- Search -->
        <div class="relative hidden sm:block">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-500 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input id="searchInput" type="text" placeholder="Search users…"
            class="pl-8 pr-4 py-2 text-xs bg-white/5 border border-white/10 rounded-lg focus:outline-none focus:ring-1 focus:ring-indigo-500/50 text-slate-200 placeholder-slate-500 w-48 transition-all focus:w-60"
            oninput="filterUsers(this.value)" />
        </div>

        <!-- Add User btn -->
        <a href="/add" class="flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-600 px-3.5 py-2 rounded-lg transition-colors shadow-lg shadow-indigo-500/20">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
          Add User
        </a>
      </div>
    </header>

    <!-- Page body -->
    <main class="flex-1 p-5 sm:p-7 space-y-6 overflow-auto">

      <!-- Stats row -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 fade-up">

        <div class="stat-card bg-[#16161d] border border-white/5 rounded-2xl p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="w-9 h-9 rounded-xl bg-indigo-500/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
          </div>
          <p class="text-2xl font-display font-700 text-white"><%= typeof users !== 'undefined' ? users.length : 0 %></p>
          <p class="text-xs text-slate-500 mt-0.5">Total Users</p>
        </div>

        <div class="stat-card bg-[#16161d] border border-white/5 rounded-2xl p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="w-9 h-9 rounded-xl bg-emerald-500/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
          </div>
          <p class="text-2xl font-display font-700 text-white">
            <% if (typeof users !== 'undefined' && users.length > 0) { %>#<%= users[users.length - 1].id %><% } else { %>—<% } %>
          </p>
          <p class="text-xs text-slate-500 mt-0.5">Latest ID</p>
        </div>

        <div class="stat-card bg-[#16161d] border border-white/5 rounded-2xl p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="w-9 h-9 rounded-xl bg-violet-500/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
          </div>
          <p class="text-2xl font-display font-700 text-white">Node</p>
          <p class="text-xs text-slate-500 mt-0.5">Runtime</p>
        </div>

        <div class="stat-card bg-[#16161d] border border-white/5 rounded-2xl p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="w-9 h-9 rounded-xl bg-amber-500/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
          </div>
          <p class="text-2xl font-display font-700 text-emerald-400 flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-emerald-400 inline-block animate-pulse"></span>Live
          </p>
          <p class="text-xs text-slate-500 mt-0.5">System Status</p>
        </div>
      </div>

      <!-- Mobile search -->
      <div class="sm:hidden">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" placeholder="Search users…"
            class="w-full pl-9 pr-4 py-2.5 text-sm bg-[#16161d] border border-white/10 rounded-xl focus:outline-none focus:ring-1 focus:ring-indigo-500/50 text-slate-200 placeholder-slate-500"
            oninput="filterUsers(this.value)" />
        </div>
      </div>

      <!-- Users Table Card -->
      <div class="bg-[#16161d] border border-white/5 rounded-2xl overflow-hidden fade-up" style="animation-delay:0.1s">

        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
          <div>
            <h2 class="font-display font-600 text-sm text-white">All Users</h2>
            <p class="text-xs text-slate-500 mt-0.5">
              <%= typeof users !== 'undefined' ? users.length : 0 %> records in database
            </p>
          </div>
          <a href="/add" class="text-xs text-indigo-400 hover:text-indigo-300 font-500 flex items-center gap-1 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
            New
          </a>
        </div>

        <!-- Table header -->
        <div class="hidden sm:grid grid-cols-12 px-6 py-3 text-[10px] font-600 text-slate-500 uppercase tracking-widest border-b border-white/5">
          <span class="col-span-1">#</span>
          <span class="col-span-1">ID</span>
          <span class="col-span-4">Name</span>
          <span class="col-span-4">Email</span>
          <span class="col-span-2 text-right">Actions</span>
        </div>

        <!-- User rows -->
        <ul id="userList" class="divide-y divide-white/5">
          <% if (typeof users !== 'undefined' && users.length > 0) { %>
            <% users.forEach(function(user, i) { %>
              <li class="user-row grid grid-cols-7 sm:grid-cols-12 items-center px-4 sm:px-6 py-3.5 hover:bg-white/3 transition-colors"
                  data-name="<%= user.name.toLowerCase() %>"
                  data-email="<%= user.email.toLowerCase() %>">

                <!-- Row number (hidden mobile) -->
                <span class="hidden sm:block col-span-1 text-xs text-slate-600 font-mono"><%= i + 1 %>.</span>

                <!-- ID -->
                <span class="hidden sm:block col-span-1 text-xs font-mono text-slate-500">#<%= user.id %></span>

                <!-- Avatar + Name -->
                <div class="col-span-4 sm:col-span-4 flex items-center gap-3 min-w-0">
                  <div class="avatar w-8 h-8 rounded-full flex-shrink-0 flex items-center justify-center text-white text-xs font-600">
                    <%= user.name.charAt(0).toUpperCase() %>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-500 text-white truncate"><%= user.name %></p>
                    <p class="text-xs text-slate-500 sm:hidden truncate"><%= user.email %></p>
                  </div>
                </div>

                <!-- Email -->
                <div class="hidden sm:flex col-span-4 items-center gap-1.5 min-w-0">
                  <span class="text-sm text-slate-400 truncate"><%= user.email %></span>
                </div>

                <!-- Actions -->
                <div class="col-span-3 sm:col-span-2 flex items-center justify-end gap-1">
                  <a href="/view/<%= user.id %>" title="View"
                    class="action-btn w-8 h-8 flex items-center justify-center rounded-lg text-slate-500 hover:text-indigo-400 hover:bg-indigo-500/10">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </a>
                  <a href="/edit/<%= user.id %>" title="Edit"
                    class="action-btn w-8 h-8 flex items-center justify-center rounded-lg text-slate-500 hover:text-amber-400 hover:bg-amber-500/10">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </a>
                  <button title="Delete" onclick="confirmDelete('<%= user.id %>', '<%= user.name %>')"
                    class="action-btn w-8 h-8 flex items-center justify-center rounded-lg text-slate-500 hover:text-red-400 hover:bg-red-500/10">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                  </button>
                </div>

              </li>
            <% }) %>
          <% } else { %>
            <li class="flex flex-col items-center justify-center py-20 text-center">
              <div class="w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center mb-4">
                <svg class="w-7 h-7 text-slate-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <p class="text-sm font-600 text-slate-300">No users found</p>
              <p class="text-xs text-slate-600 mt-1 mb-4">Get started by adding your first user</p>
              <a href="/add" class="inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-600 px-4 py-2 rounded-lg transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                Add First User
              </a>
            </li>
          <% } %>
        </ul>

        <!-- No search results -->
        <div id="noResults" class="hidden flex-col items-center justify-center py-14 text-center">
          <svg class="w-10 h-10 text-slate-700 mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <p class="text-sm text-slate-500">No results match your search</p>
        </div>

      </div>
    </main>
  </div>

  <!-- ===== DELETE MODAL ===== -->
  <div id="deleteModal" class="modal-overlay fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeModal()"></div>
    <div id="modalBox" class="modal-box relative bg-[#1e1e28] border border-white/10 rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4 z-10 scale-95 opacity-0">
      <div class="w-12 h-12 rounded-2xl bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      </div>
      <h3 class="font-display font-700 text-base text-center text-white">Delete User?</h3>
      <p class="text-sm text-slate-400 text-center mt-2">
        You're about to permanently delete <strong id="deleteUserName" class="text-slate-200"></strong>. This cannot be undone.
      </p>
      <div class="flex gap-3 mt-6">
        <button onclick="closeModal()"
          class="flex-1 py-2.5 text-sm font-500 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 text-slate-300 transition-colors">
          Cancel
        </button>
        <a id="deleteConfirmBtn" href="#"
          class="flex-1 py-2.5 text-sm font-600 rounded-xl bg-red-600 hover:bg-red-500 text-white text-center transition-colors">
          Delete
        </a>
      </div>
    </div>
  </div>

  <script>
    function openSidebar() {
      document.getElementById('sidebar').classList.remove('-translate-x-full');
      document.getElementById('sidebarOverlay').classList.remove('opacity-0', 'pointer-events-none');
      document.getElementById('sidebarOverlay').classList.add('opacity-100');
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.add('-translate-x-full');
      document.getElementById('sidebarOverlay').classList.add('opacity-0', 'pointer-events-none');
      document.getElementById('sidebarOverlay').classList.remove('opacity-100');
    }

    function filterUsers(query) {
      const q = query.toLowerCase().trim();
      const rows = document.querySelectorAll('#userList .user-row');
      const noResults = document.getElementById('noResults');
      let visible = 0;
      rows.forEach(row => {
        const match = row.dataset.name.includes(q) || row.dataset.email.includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
      noResults.classList.toggle('flex', visible === 0);
    }

    function confirmDelete(id, name) {
      document.getElementById('deleteUserName').textContent = name;
      document.getElementById('deleteConfirmBtn').href = '/delete/' + id;
      const modal = document.getElementById('deleteModal');
      const box = document.getElementById('modalBox');
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.classList.add('opacity-100');
      box.classList.remove('scale-95', 'opacity-0');
      box.classList.add('scale-100', 'opacity-100');
    }

    function closeModal() {
      const modal = document.getElementById('deleteModal');
      const box = document.getElementById('modalBox');
      modal.classList.add('opacity-0', 'pointer-events-none');
      modal.classList.remove('opacity-100');
      box.classList.add('scale-95', 'opacity-0');
      box.classList.remove('scale-100', 'opacity-100');
    }

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
  </script>
</body>
</html>
