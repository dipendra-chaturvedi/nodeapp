<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add User — UserHub</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { fontFamily: { display: ['Syne','sans-serif'], body: ['DM Sans','sans-serif'] } } }
    }
  </script>
  <style>
    * { font-family: 'DM Sans', sans-serif; }
    h1,h2,h3,.font-display { font-family: 'Syne', sans-serif; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #0f0f13; }
    ::-webkit-scrollbar-thumb { background: #6366f140; border-radius: 2px; }
    .sidebar { transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); }
    .nav-link { transition: all 0.15s ease; position: relative; }
    .nav-link::before {
      content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
      width: 3px; height: 0; background: #6366f1; border-radius: 0 2px 2px 0; transition: height 0.2s ease;
    }
    .nav-link.active::before, .nav-link:hover::before { height: 60%; }
    .nav-link.active { background: #6366f115; color: #818cf8; }
    .glow-dot { box-shadow: 0 0 0 3px #10b98130; }
    .input-field {
      background: #1e1e28; border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .input-field:focus {
      outline: none; border-color: #6366f1;
      box-shadow: 0 0 0 3px #6366f120;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.35s ease both; }
    .sidebar-overlay { transition: opacity 0.3s ease; }
  </style>
</head>

<body class="bg-[#0f0f13] text-slate-100 min-h-screen flex overflow-x-hidden">

  <!-- Mobile Overlay -->
  <div id="sidebarOverlay" onclick="closeSidebar()"
    class="sidebar-overlay fixed inset-0 bg-black/60 backdrop-blur-sm z-30 opacity-0 pointer-events-none lg:hidden"></div>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar fixed lg:static top-0 left-0 z-40 w-64 h-screen bg-[#16161d] border-r border-white/5 flex flex-col -translate-x-full lg:translate-x-0 flex-shrink-0">
    <div class="flex items-center gap-3 px-6 py-5 border-b border-white/5">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center shadow-lg shadow-indigo-500/25">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <circle cx="9" cy="7" r="3" fill="white"/>
          <path d="M3 16c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <p class="font-display font-700 text-sm text-white leading-none">UserHub</p>
        <p class="text-[10px] text-slate-500 mt-0.5">Admin Panel</p>
      </div>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <p class="text-[10px] font-600 text-slate-600 uppercase tracking-widest px-3 mb-2">Menu</p>
      <a href="/" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-400 hover:text-slate-200 hover:bg-white/5">
        <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </span>
        Dashboard
      </a>
      <a href="/add" class="nav-link active flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-200">
        <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
        </span>
        Add User
      </a>
      <div class="pt-4">
        <p class="text-[10px] font-600 text-slate-600 uppercase tracking-widest px-3 mb-2">System</p>
        <a href="#" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-400 hover:text-slate-200 hover:bg-white/5">
          <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 text-slate-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 1 0 4.93 19.07"/></svg>
          </span>
          Settings
        </a>
      </div>
    </nav>
    <div class="px-4 py-4 border-t border-white/5">
      <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-emerald-500/5 border border-emerald-500/10">
        <span class="glow-dot w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
        <div>
          <p class="text-xs font-500 text-emerald-300">Database Online</p>
          <p class="text-[10px] text-slate-500">MySQL · Connected</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="flex-1 flex flex-col min-w-0">
    <header class="sticky top-0 z-20 bg-[#0f0f13]/80 backdrop-blur border-b border-white/5 px-5 py-3.5 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden w-9 h-9 flex items-center justify-center rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="flex items-center gap-2 text-sm text-slate-500">
        <a href="/" class="hover:text-slate-300 transition-colors">Dashboard</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-slate-300">Add User</span>
      </div>
    </header>

    <main class="flex-1 p-5 sm:p-7 flex items-start justify-center">
      <div class="w-full max-w-lg fade-up">

        <!-- Card -->
        <div class="bg-[#16161d] border border-white/5 rounded-2xl overflow-hidden">

          <!-- Card Header -->
          <div class="px-6 py-5 border-b border-white/5 flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            </div>
            <div>
              <h1 class="font-display font-700 text-base text-white">Add New User</h1>
              <p class="text-xs text-slate-500 mt-0.5">Fill in the details below to create a user</p>
            </div>
          </div>

          <!-- Form -->
          <form action="/add" method="POST" class="px-6 py-6 space-y-5">

            <div class="space-y-1.5">
              <label class="text-xs font-600 text-slate-400 uppercase tracking-wider">Full Name</label>
              <div class="relative">
                <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <input type="text" name="name" required placeholder="e.g. Arjun Sharma"
                  class="input-field w-full pl-10 pr-4 py-3 text-sm text-slate-100 placeholder-slate-600" />
              </div>
            </div>

            <div class="space-y-1.5">
              <label class="text-xs font-600 text-slate-400 uppercase tracking-wider">Email Address</label>
              <div class="relative">
                <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <input type="email" name="email" required placeholder="e.g. arjun@example.com"
                  class="input-field w-full pl-10 pr-4 py-3 text-sm text-slate-100 placeholder-slate-600" />
              </div>
            </div>

            <div class="flex gap-3 pt-1">
              <a href="/"
                class="flex-1 py-3 text-sm font-600 text-center rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 text-slate-300 transition-colors">
                Cancel
              </a>
              <button type="submit"
                class="flex-1 py-3 text-sm font-600 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white transition-colors shadow-lg shadow-indigo-500/20 flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                Create User
              </button>
            </div>

          </form>
        </div>

        <!-- Info note -->
        <p class="text-center text-xs text-slate-600 mt-4">
          User will be added to the MySQL database immediately.
        </p>
      </div>
    </main>
  </div>

  <script>
    function openSidebar() {
      document.getElementById('sidebar').classList.remove('-translate-x-full');
      document.getElementById('sidebarOverlay').classList.remove('opacity-0','pointer-events-none');
      document.getElementById('sidebarOverlay').classList.add('opacity-100');
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.add('-translate-x-full');
      document.getElementById('sidebarOverlay').classList.add('opacity-0','pointer-events-none');
      document.getElementById('sidebarOverlay').classList.remove('opacity-100');
    }
  </script>
</body>
</html>
