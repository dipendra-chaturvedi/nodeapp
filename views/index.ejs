<h2>User List</h2>
<a href="/add">Add User</a>

<ul>
<% users.forEach(user => { %>
    <li>
        <%= user.name %> - <%= user.email %>
        | <a href="/view/<%= user.id %>">View</a>
        | <a href="/edit/<%= user.id %>">Edit</a>
        | <a href="/delete/<%= user.id %>">Delete</a>
    </li>
<% }) %>
</ul>