<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>View User — UserHub</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { fontFamily: { display: ['Syne','sans-serif'], body: ['DM Sans','sans-serif'] } } }
    }
  </script>
  <style>
    * { font-family: 'DM Sans', sans-serif; }
    h1,h2,h3,.font-display { font-family: 'Syne', sans-serif; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #0f0f13; }
    ::-webkit-scrollbar-thumb { background: #6366f140; border-radius: 2px; }
    .sidebar { transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); }
    .nav-link { transition: all 0.15s ease; position: relative; }
    .nav-link::before {
      content:''; position:absolute; left:0; top:50%; transform:translateY(-50%);
      width:3px; height:0; background:#6366f1; border-radius:0 2px 2px 0; transition:height 0.2s ease;
    }
    .nav-link.active::before, .nav-link:hover::before { height:60%; }
    .nav-link.active { background:#6366f115; color:#818cf8; }
    .glow-dot { box-shadow: 0 0 0 3px #10b98130; }
    @keyframes fadeUp {
      from { opacity:0; transform:translateY(12px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .fade-up { animation: fadeUp 0.35s ease both; }
    .sidebar-overlay { transition: opacity 0.3s ease; }
    .avatar-xl { background: linear-gradient(135deg, #6366f1, #a78bfa); }
    .detail-row { transition: background 0.15s ease; }
    .detail-row:hover { background: rgba(255,255,255,0.03); }
  </style>
</head>

<body class="bg-[#0f0f13] text-slate-100 min-h-screen flex overflow-x-hidden">

  <div id="sidebarOverlay" onclick="closeSidebar()"
    class="sidebar-overlay fixed inset-0 bg-black/60 backdrop-blur-sm z-30 opacity-0 pointer-events-none lg:hidden"></div>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar fixed lg:static top-0 left-0 z-40 w-64 h-screen bg-[#16161d] border-r border-white/5 flex flex-col -translate-x-full lg:translate-x-0 flex-shrink-0">
    <div class="flex items-center gap-3 px-6 py-5 border-b border-white/5">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center shadow-lg shadow-indigo-500/25">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <circle cx="9" cy="7" r="3" fill="white"/>
          <path d="M3 16c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <p class="font-display font-700 text-sm text-white leading-none">UserHub</p>
        <p class="text-[10px] text-slate-500 mt-0.5">Admin Panel</p>
      </div>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <p class="text-[10px] font-600 text-slate-600 uppercase tracking-widest px-3 mb-2">Menu</p>
      <a href="/" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-400 hover:text-slate-200 hover:bg-white/5">
        <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </span>
        Dashboard
      </a>
      <a href="/add" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-400 hover:text-slate-200 hover:bg-white/5">
        <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
        </span>
        Add User
      </a>
      <div class="pt-4">
        <p class="text-[10px] font-600 text-slate-600 uppercase tracking-widest px-3 mb-2">System</p>
        <a href="#" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-500 text-slate-400 hover:text-slate-200 hover:bg-white/5">
          <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 text-slate-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 1 0 4.93 19.07"/></svg>
          </span>
          Settings
        </a>
      </div>
    </nav>
    <div class="px-4 py-4 border-t border-white/5">
      <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-emerald-500/5 border border-emerald-500/10">
        <span class="glow-dot w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
        <div>
          <p class="text-xs font-500 text-emerald-300">Database Online</p>
          <p class="text-[10px] text-slate-500">MySQL · Connected</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="flex-1 flex flex-col min-w-0">
    <header class="sticky top-0 z-20 bg-[#0f0f13]/80 backdrop-blur border-b border-white/5 px-5 py-3.5 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden w-9 h-9 flex items-center justify-center rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="flex items-center gap-2 text-sm text-slate-500">
        <a href="/" class="hover:text-slate-300 transition-colors">Dashboard</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-slate-300">View User</span>
      </div>
    </header>

    <main class="flex-1 p-5 sm:p-7 flex items-start justify-center">
      <div class="w-full max-w-lg fade-up">

        <!-- Profile Card -->
        <div class="bg-[#16161d] border border-white/5 rounded-2xl overflow-hidden">

          <!-- Profile Hero -->
          <div class="relative px-6 pt-8 pb-6 text-center border-b border-white/5" style="background: radial-gradient(ellipse at top, #6366f108 0%, transparent 70%);">
            <!-- ID badge -->
            <span class="absolute top-4 right-4 text-xs font-mono text-slate-600 bg-white/5 px-2.5 py-1 rounded-lg border border-white/5">#<%= user.id %></span>

            <!-- Avatar -->
            <div class="avatar-xl w-20 h-20 rounded-2xl flex items-center justify-center text-white text-3xl font-display font-800 mx-auto shadow-2xl shadow-indigo-500/20">
              <%= user.name.charAt(0).toUpperCase() %>
            </div>

            <h1 class="font-display font-700 text-xl text-white mt-4"><%= user.name %></h1>
            <p class="text-sm text-slate-400 mt-1"><%= user.email %></p>

            <!-- Status badge -->
            <div class="inline-flex items-center gap-1.5 mt-3 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
              <span class="text-xs font-600 text-emerald-400">Active User</span>
            </div>
          </div>

          <!-- User Details -->
          <div class="divide-y divide-white/5">
            <div class="detail-row flex items-center justify-between px-6 py-4 rounded-none">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-500">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <span class="text-xs text-slate-500 uppercase tracking-wider font-600">Full Name</span>
              </div>
              <span class="text-sm text-slate-200 font-500"><%= user.name %></span>
            </div>

            <div class="detail-row flex items-center justify-between px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-500">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <span class="text-xs text-slate-500 uppercase tracking-wider font-600">Email</span>
              </div>
              <span class="text-sm text-slate-200 font-500"><%= user.email %></span>
            </div>

            <div class="detail-row flex items-center justify-between px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-500">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                </div>
                <span class="text-xs text-slate-500 uppercase tracking-wider font-600">User ID</span>
              </div>
              <span class="text-sm font-mono text-indigo-400">#<%= user.id %></span>
            </div>
          </div>

          <!-- Action buttons -->
          <div class="px-6 py-5 border-t border-white/5 flex gap-3">
            <a href="/edit/<%= user.id %>"
              class="flex-1 flex items-center justify-center gap-2 py-3 text-sm font-600 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white transition-colors shadow-lg shadow-indigo-500/20">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              Edit User
            </a>
            <button onclick="confirmDelete('<%= user.id %>', '<%= user.name %>')"
              class="flex items-center justify-center gap-2 px-4 py-3 text-sm font-600 rounded-xl border border-red-500/30 bg-red-500/5 hover:bg-red-500/15 text-red-400 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
              Delete
            </button>
            <a href="/"
              class="flex items-center justify-center px-4 py-3 text-sm font-600 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 text-slate-400 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
            </a>
          </div>
        </div>

      </div>
    </main>
  </div>

  <!-- DELETE MODAL -->
  <div id="deleteModal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none" style="transition:opacity 0.2s">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeModal()"></div>
    <div id="modalBox" class="relative bg-[#1e1e28] border border-white/10 rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4 z-10 scale-95 opacity-0" style="transition:all 0.25s cubic-bezier(0.16,1,0.3,1)">
      <div class="w-12 h-12 rounded-2xl bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      </div>
      <h3 class="font-display font-700 text-base text-center text-white">Delete User?</h3>
      <p class="text-sm text-slate-400 text-center mt-2">Permanently delete <strong id="deleteUserName" class="text-slate-200"></strong>? This cannot be undone.</p>
      <div class="flex gap-3 mt-6">
        <button onclick="closeModal()" class="flex-1 py-2.5 text-sm font-500 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 text-slate-300 transition-colors">Cancel</button>
        <a id="deleteConfirmBtn" href="#" class="flex-1 py-2.5 text-sm font-600 rounded-xl bg-red-600 hover:bg-red-500 text-white text-center transition-colors">Delete</a>
      </div>
    </div>
  </div>

  <script>
    function openSidebar() {
      document.getElementById('sidebar').classList.remove('-translate-x-full');
      document.getElementById('sidebarOverlay').classList.remove('opacity-0','pointer-events-none');
      document.getElementById('sidebarOverlay').classList.add('opacity-100');
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.add('-translate-x-full');
      document.getElementById('sidebarOverlay').classList.add('opacity-0','pointer-events-none');
      document.getElementById('sidebarOverlay').classList.remove('opacity-100');
    }
    function confirmDelete(id, name) {
      document.getElementById('deleteUserName').textContent = name;
      document.getElementById('deleteConfirmBtn').href = '/delete/' + id;
      const modal = document.getElementById('deleteModal');
      const box = document.getElementById('modalBox');
      modal.classList.remove('opacity-0','pointer-events-none');
      modal.classList.add('opacity-100');
      box.classList.remove('scale-95','opacity-0');
      box.classList.add('scale-100','opacity-100');
    }
    function closeModal() {
      const modal = document.getElementById('deleteModal');
      const box = document.getElementById('modalBox');
      modal.classList.add('opacity-0','pointer-events-none');
      modal.classList.remove('opacity-100');
      box.classList.add('scale-95','opacity-0');
      box.classList.remove('scale-100','opacity-100');
    }
    document.addEventListener('keydown', e => { if(e.key === 'Escape') closeModal(); });
  </script>
</body>
</html>
